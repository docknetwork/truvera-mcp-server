{
  "name": "truvera-mcp-service",
  "version": "1.0.0",
  "description": "MCP service for Truvera API integration with Docker support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node scripts/update-build-version.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx tests/smoke-list-tools.ts",
    "test": "vitest",
    "e2e": "vitest tests/e2e --run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/request": "^2.48.13",
    "dotenv": "^16.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
