# Wallet MCP Server Configuration

# Master encryption key for wallet (required)
WALLET_MASTER_KEY=your-master-key-here

# Transport mode: "stdio" (default) or "http"
MCP_MODE=stdio

# HTTP port (only used if MCP_MODE=http)
MCP_PORT=3001

# EDV Storage Configuration (Encrypted Data Vault)
EDV_STORAGE_URL=https://edv.dock.io

# Optional: Wallet name/label
WALLET_NAME=my-wallet
