# Wallet MCP Server Configuration

# Master encryption key for wallet (required)
WALLET_MASTER_KEY=your-master-key-here

# Transport mode: "stdio" (default) or "http"
MCP_MODE=stdio

# HTTP port (only used if MCP_MODE=http)
MCP_PORT=3001

# Optional: Wallet name/label
WALLET_NAME=my-wallet

# Cheqd network: "testnet" or "mainnet"
CHEQD_NETWORK=testnet

# Host path for the SQLite wallet database (required when using docker:run:wallet).
# The parent directory is created automatically if it doesn't exist.
# The filename within the directory is used as the database name inside the container.
# Example: WALLET_DB_PATH=/home/you/wallet-data/wallet-db
WALLET_DB_PATH=
